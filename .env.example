# API_KEY must match the X-API-Key header on every client (curl, HappyRobot webhooks, dashboard).
# On Railway, set the service variable API_KEY to the same value (demo default below).
# If HappyRobot stores this as a workflow secret (e.g. railwayapikey), bind it to header X-API-Key.
# SKIP_API_KEY_AUTH=true  # optional: disable API key (LOCAL/private demos only; never on public prod)
API_KEY=sk-testkey
DATABASE_URL=sqlite:///./data/loads.db
REDIS_URL=redis://localhost:6379/0
FMCSA_WEB_KEY=
FMCSA_KEY=
DASHBOARD_ENTRY_URL=http://127.0.0.1:8501
API_BASE_URL=http://127.0.0.1:8000
API_METRICS_PATH=/v1/metrics
